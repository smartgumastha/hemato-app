{
  "rewrites": [
    { "source": "/backend/:path*", "destination": "https://smartgumastha-backend-production.up.railway.app/:path*" }
  ],
  "headers": [
    {
      "source": "/app.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ]
}
